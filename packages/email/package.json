{
  "name": "@dwete/email",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "dev": "email dev --dir ./src/templates -p 3333"
  },
  "dependencies": {
    "@react-email/components": "latest",
    "@react-email/markdown": "latest",
    "@react-email/render": "latest",
    "nodemailer": "latest",
    "react": "latest",
    "react-email": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@dwete/biome": "workspace:*",
    "@react-email/preview-server": "latest",
    "@types/bun": "latest",
    "@types/nodemailer": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  },
  "exports": {
    ".": {
      "import": "./src/mailer.ts",
      "require": "./src/mailer.ts"
    },
    "./templates/*": {
      "import": "./src/templates/*.tsx",
      "require": "./src/templates/*.tsx"
    },
    "./mailer": {
      "import": "./src/mailer.ts",
      "require": "./src/mailer.ts"
    }
  }
}
